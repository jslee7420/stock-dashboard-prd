{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "crons": [
    { "path": "/api/cron/screening", "schedule": "0 9 * * 1-5" },
    { "path": "/api/cron/signals", "schedule": "0 11 * * 1-5" }
  ]
}
